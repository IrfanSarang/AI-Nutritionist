{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "api/**/*",
    "controllers/**/*",
    "routes/**/*",
    "models/**/*",
    "config/**/*",
    "middleware/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
